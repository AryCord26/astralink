generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String
  createdAt DateTime @default(now())
}

model Message {
  id          String   @id @default(cuid())
  sender      String
  content     String
  delivered   Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model Task {
  id          String   @id @default(cuid())
  title       String
  description String
  priority    String
  status      String
  assignedTo  String
  createdAt   DateTime @default(now())
}
